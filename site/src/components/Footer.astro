---
import config from "@/config";
import { withBase } from "@/utils/withBase";

const year = new Date().getFullYear();
---

<footer class="app-layout mt-auto">
  <div
    class="border-border flex flex-col items-center justify-between border-t py-6 text-sm sm:flex-row-reverse sm:py-4"
  >
    <nav aria-label="Footer navigation" class="my-2 flex gap-4">
      <a href={withBase("docs/")} class="hover:text-accent">Docs</a>
      <a href={config.site.repositoryUrl} class="hover:text-accent">Source</a>
      <a href="https://github.com/satnaing/astro-paper" class="hover:text-accent"
        >AstroPaper</a
      >
    </nav>
    <p class="my-2 text-center sm:text-start">
      © {year} Rararulab <span class="hidden sm:inline">·</span><br class="sm:hidden" /> Apache-2.0
    </p>
  </div>
</footer>
