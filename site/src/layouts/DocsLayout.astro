---
import type { DocEntry } from "@/utils/docs";
import DocsNav from "@/components/DocsNav.astro";
import Footer from "@/components/Footer.astro";
import Header from "@/components/Header.astro";
import Layout from "@/layouts/Layout.astro";
import { withBase } from "@/utils/withBase";

interface Props {
  docs: DocEntry[];
  currentSlug: string;
  title: string;
  description?: string;
}

const { docs, currentSlug, title, description } = Astro.props;
---

<Layout title={title} description={description}>
  <Header />
  <main id="main-content" class="app-layout flex-1 py-8" data-pagefind-body>
    <nav
      aria-label="Breadcrumb"
      class="text-muted-foreground mb-6 flex items-center gap-2 text-sm"
    >
      <a href={withBase("")} class="hover:text-accent">lake</a>
      <span aria-hidden="true">/</span>
      <a href={withBase("docs/")} class="hover:text-accent">docs</a>
      <span aria-hidden="true">/</span>
      <span class="text-foreground truncate" aria-current="page">{title}</span>
    </nav>

    <details class="border-border mb-8 border-y py-3">
      <summary class="hover:text-accent cursor-pointer font-medium">
        Browse this documentation section
      </summary>
      <div class="pt-5 pb-2">
        <DocsNav docs={docs} currentSlug={currentSlug} />
      </div>
    </details>

    <article class="app-prose">
      <slot />
    </article>
  </main>
  <Footer />
</Layout>
