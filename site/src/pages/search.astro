---
import "@pagefind/default-ui/css/ui.css";
import Footer from "@/components/Footer.astro";
import Header from "@/components/Header.astro";
import Layout from "@/layouts/Layout.astro";
import { withBase } from "@/utils/withBase";

const bundlePath = withBase("pagefind/");
---

<Layout title="Search" description="Search lake documentation.">
  <Header />
  <main id="main-content" class="app-layout flex-1 py-8">
    <h1 class="text-2xl font-semibold sm:text-3xl">Search</h1>
    <p class="mt-2 mb-6 italic">
      Search the landing page and every published document.
    </p>
    <div id="pagefind-search" class="mt-8" data-bundle-path={bundlePath}></div>
  </main>
  <Footer />
</Layout>

<script>
  async function initializeSearch() {
    const element = document.querySelector<HTMLElement>("#pagefind-search");
    if (!element || element.querySelector("form")) return;

    const bundlePath = element.dataset.bundlePath;
    if (!bundlePath) return;

    if (import.meta.env.DEV) {
      element.innerHTML =
        "<p>Build the site once to create the local search index.</p>";
      return;
    }

    // @ts-expect-error Pagefind's browser bundle does not publish complete TypeScript declarations.
    const { PagefindUI } = await import("@pagefind/default-ui");
    new PagefindUI({
      element: "#pagefind-search",
      bundlePath,
      showImages: false,
      showSubResults: true,
    });
  }

  initializeSearch();
</script>

<style is:global>
  #pagefind-search {
    --pagefind-ui-font: var(--font-app);
    --pagefind-ui-text: var(--foreground);
    --pagefind-ui-background: var(--background);
    --pagefind-ui-border: var(--border);
    --pagefind-ui-primary: var(--accent);
    --pagefind-ui-tag: var(--background);
    --pagefind-ui-border-radius: 0.375rem;
    --pagefind-ui-border-width: 1px;

    form::before {
      background-color: var(--foreground);
    }

    input {
      border: 1px solid var(--border);
      font-weight: 400;
    }

    input:focus-visible {
      outline: 1px solid var(--accent);
    }

    .pagefind-ui__result-title a {
      color: var(--accent);
      text-decoration-style: dashed;
      text-underline-offset: 4px;
    }

    .pagefind-ui__result-title a:focus-visible,
    .pagefind-ui__search-clear:focus-visible {
      text-decoration-line: none;
      outline-width: 2px;
      outline-style: dashed;
    }
  }
</style>
