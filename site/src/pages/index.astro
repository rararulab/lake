---
import { getCollection } from "astro:content";
import config from "@/config";
import DocCard from "@/components/DocCard.astro";
import Footer from "@/components/Footer.astro";
import Header from "@/components/Header.astro";
import Layout from "@/layouts/Layout.astro";
import { getDocSlug, isPublicDoc } from "@/utils/docs";
import { withBase } from "@/utils/withBase";

const docs = (await getCollection("docs")).filter(isPublicDoc);
const featuredDocs = [
  {
    slug: "architecture",
    description:
      "How stateless SQL compute, bounded metadata authority, and object storage fit together.",
  },
  {
    slug: "design/robot-training-lakehouse",
    description:
      "The product loop, data model, current capability boundary, and delivery direction.",
  },
  {
    slug: "guides/local-deploy",
    description:
      "Run the complete local stack and exercise ingest, commit, and SQL reads.",
  },
].flatMap(item => {
  const entry = docs.find(doc => getDocSlug(doc) === item.slug);
  return entry ? [{ entry, description: item.description }] : [];
});
---

<Layout>
  <Header />
  <main id="main-content" data-layout="index" class="app-layout" data-pagefind-body>
    <section id="hero" class="border-border border-b pt-8 pb-6 sm:pt-12 sm:pb-10">
      <h1 class="my-4 inline-block text-4xl font-bold sm:my-8 sm:text-5xl">lake</h1>
      <p class="max-w-[65ch]">
        An open-source lakehouse for embodied-AI data. Robot fleets write immutable
        episode data; stateless DataFusion query nodes read exact table versions
        directly from object storage through Arrow Flight SQL.
      </p>
      <p class="mt-3 max-w-[65ch]">
        The metadata layer remains a bounded catalog authority while query replicas
        absorb concurrent training and evaluation reads behind local caches.
      </p>
      <p class="mt-4 flex flex-wrap gap-x-5 gap-y-2">
        <a
          href={withBase("docs/")}
          class="hover:text-accent underline decoration-dashed underline-offset-4"
        >
          Read the documentation
        </a>
        <a
          href={config.site.repositoryUrl}
          class="hover:text-accent underline decoration-dashed underline-offset-4"
        >
          View source on GitHub
        </a>
      </p>
    </section>

    <section id="documentation" class="pt-12 pb-6">
      <h2 class="text-2xl font-semibold tracking-wide">Documentation</h2>
      <p class="mt-2 italic">
        Start with the architecture, the robot-training direction, or a local
        deployment. Every page is rendered from the repository's canonical
        <code class="bg-muted/75 rounded p-1">docs/</code> Markdown.
      </p>
      <ul class="m-0 p-0">
        {
          featuredDocs.map(({ entry, description }) => (
            <DocCard entry={entry} description={description} />
          ))
        }
      </ul>
    </section>

    <div class="my-8 text-center">
      <a
        href={withBase("docs/")}
        class="hover:text-accent inline-flex items-center gap-1"
      >
        Browse all documentation <span aria-hidden="true">→</span>
      </a>
    </div>
  </main>
  <Footer />
</Layout>
