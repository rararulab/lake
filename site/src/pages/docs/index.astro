---
import { getCollection } from "astro:content";
import DocCard from "@/components/DocCard.astro";
import DocsNav from "@/components/DocsNav.astro";
import Footer from "@/components/Footer.astro";
import Header from "@/components/Header.astro";
import Layout from "@/layouts/Layout.astro";
import { getDocSection, isPublicDoc, sortDocs } from "@/utils/docs";

const docs = sortDocs((await getCollection("docs")).filter(isPublicDoc));
const sections = Map.groupBy(docs, getDocSection);
const descriptions: Record<string, string> = {
  overview: "System architecture and project-wide documentation.",
  design: "Focused decisions for metadata, storage, and SQL paths.",
  guides: "Contributor workflows, operations, CLI, and deployment guidance.",
  plans: "Implementation plans that preserve the reasoning behind major changes.",
};
---

<Layout
  title="Documentation"
  description="Architecture, design notes, guides, and implementation plans for lake."
>
  <Header />
  <main id="main-content" class="app-layout flex-1 py-8" data-pagefind-body>
    <h1 class="text-2xl font-semibold sm:text-3xl">Documentation</h1>
    <p class="mt-2 mb-6 italic">
      Architecture, design decisions, contributor guides, and implementation plans
      rendered directly from the repository's canonical docs.
    </p>

    <details class="border-border my-6 border-y py-3">
      <summary class="hover:text-accent cursor-pointer font-medium">
        Browse documentation sections
      </summary>
      <div class="pt-5 pb-2">
        <DocsNav docs={docs} />
      </div>
    </details>

    {
      [...sections].map(([section, entries]) => (
        <section id={section} class="border-border scroll-mt-4 border-b pt-8 pb-4">
          <h2 class="text-2xl font-semibold tracking-wide capitalize">
            {section.replaceAll("-", " ")}
          </h2>
          <p class="mt-2 italic">{descriptions[section]}</p>
          <ul class="m-0 p-0">
            {entries.map(entry => (
              <DocCard entry={entry} />
            ))}
          </ul>
        </section>
      ))
    }
  </main>
  <Footer />
</Layout>
