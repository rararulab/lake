---
import Footer from "@/components/Footer.astro";
import Header from "@/components/Header.astro";
import Layout from "@/layouts/Layout.astro";
import { withBase } from "@/utils/withBase";
---

<Layout title="Page not found">
  <Header />
  <main
    id="main-content"
    class="content-shell grid flex-1 place-items-center py-20 text-center"
  >
    <div>
      <p class="text-accent font-code text-8xl font-semibold tracking-[-0.08em]">404</p>
      <h1 class="mt-5 text-3xl font-semibold">Page not found</h1>
      <p class="text-muted-foreground mt-3">
        The route does not exist in this static build.
      </p>
      <a
        href={withBase("")}
        class="decoration-accent hover:text-accent mt-8 inline-flex rounded font-semibold underline decoration-dashed underline-offset-8"
      >
        Return home
      </a>
    </div>
  </main>
  <Footer />
</Layout>
