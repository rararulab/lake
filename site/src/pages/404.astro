---
import Footer from "@/components/Footer.astro";
import Header from "@/components/Header.astro";
import Layout from "@/layouts/Layout.astro";
import { withBase } from "@/utils/withBase";
---

<Layout title="Page not found">
  <Header />
  <main id="main-content" class="app-layout flex flex-1 items-center justify-center">
    <div class="mb-14 flex flex-col items-center justify-center text-center">
      <h1 class="text-accent text-9xl font-bold">404</h1>
      <span aria-hidden="true">¯\_(ツ)_/¯</span>
      <p class="mt-4 text-2xl sm:text-3xl">Page not found</p>
      <p class="mt-2">The route does not exist in this static build.</p>
      <a
        href={withBase("")}
        class="hover:text-accent my-6 text-lg underline decoration-dashed underline-offset-8"
      >
        Return home
      </a>
    </div>
  </main>
  <Footer />
</Layout>
