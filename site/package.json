{
  "name": "@rararulab/lake-site",
  "private": true,
  "version": "0.0.0",
  "type": "module",
  "engines": {
    "node": ">=22.12.0"
  },
  "scripts": {
    "dev": "astro dev",
    "preview": "astro preview",
    "typecheck": "astro check",
    "build": "astro build && pagefind --site dist",
    "test": "bun scripts/check-output.ts",
    "format": "prettier --write .",
    "format:check": "prettier --check .",
    "lint": "eslint .",
    "check": "bun run typecheck && bun run lint && bun run format:check && bun run build && bun run test"
  },
  "dependencies": {
    "@fontsource-variable/geist": "^5.2.9",
    "@fontsource-variable/geist-mono": "^5.2.8",
